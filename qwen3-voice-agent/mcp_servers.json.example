{
  "_comment": "Copy this file to mcp_servers.json and edit. Each entry launches a stdio MCP server whose tools the voice agent can call. Set enabled:false to keep a server defined but off. On Windows, npx-based servers are run via cmd automatically.",
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:/Users/you/Documents"],
      "enabled": false
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "enabled": false
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "enabled": false
    }
  }
}
