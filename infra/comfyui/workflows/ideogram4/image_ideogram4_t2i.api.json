{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "ideogram4_fp8_scaled.safetensors", "weight_dtype": "default"},
    "_meta": {"title": "Load Ideogram 4 (main)"}
  },
  "2": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "ideogram4_unconditional_fp8_scaled.safetensors", "weight_dtype": "default"},
    "_meta": {"title": "Load Ideogram 4 (unconditional)"}
  },
  "3": {
    "class_type": "CFGOverride",
    "inputs": {"model": ["1", 0], "cfg": 3, "start_percent": 0.7, "end_percent": 1},
    "_meta": {"title": "CFG Override"}
  },
  "4": {
    "class_type": "CLIPLoader",
    "inputs": {"clip_name": "qwen3vl_8b_fp8_scaled.safetensors", "type": "ideogram4"},
    "_meta": {"title": "Load Qwen3-VL text encoder"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{\n  \"high_level_description\": \"A cozy wooden cabin in a snowy pine forest at dusk, warm golden light glowing from the windows, soft falling snow, a thin wisp of smoke from the chimney\",\n  \"style_description\": {\n    \"aesthetics\": \"cinematic landscape photography, highly detailed, atmospheric\",\n    \"lighting\": \"warm interior window glow against cool blue dusk, soft ambient snow light\",\n    \"photo\": \"35mm, shallow depth of field, crisp foreground snow\",\n    \"color_palette\": [\"#2B3A55\", \"#F2C879\", \"#E8EEF2\", \"#3E5641\"]\n  },\n  \"compositional_deconstruction\": {\n    \"background\": \"deep blue dusk sky fading over a dense snow-laden pine forest\",\n    \"elements\": [\n      {\"type\": \"obj\", \"desc\": \"a small wooden cabin centered, warm light in the windows, snow on the roof\"},\n      {\"type\": \"obj\", \"desc\": \"foreground snowdrifts and a few tall pines framing the scene\"}\n    ]\n  }\n}",
      "clip": ["4", 0]
    },
    "_meta": {"title": "Prompt"}
  },
  "6": {
    "class_type": "ConditioningZeroOut",
    "inputs": {"conditioning": ["5", 0]},
    "_meta": {"title": "Zero (unconditional) conditioning"}
  },
  "7": {
    "class_type": "DualModelGuider",
    "inputs": {
      "model": ["3", 0],
      "positive": ["5", 0],
      "cfg": 7,
      "model_negative": ["2", 0],
      "negative": ["6", 0]
    },
    "_meta": {"title": "Dual-model guider (asymmetric CFG)"}
  },
  "8": {
    "class_type": "Ideogram4Scheduler",
    "inputs": {"steps": 20, "width": 1024, "height": 1024, "mu": 0.0, "std": 1.75},
    "_meta": {"title": "Ideogram 4 scheduler (Default preset)"}
  },
  "9": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler"},
    "_meta": {"title": "Sampler"}
  },
  "10": {
    "class_type": "RandomNoise",
    "inputs": {"noise_seed": 885894517601261},
    "_meta": {"title": "Noise"}
  },
  "11": {
    "class_type": "EmptyFlux2LatentImage",
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1},
    "_meta": {"title": "Empty latent"}
  },
  "12": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["10", 0],
      "guider": ["7", 0],
      "sampler": ["9", 0],
      "sigmas": ["8", 0],
      "latent_image": ["11", 0]
    },
    "_meta": {"title": "Sample"}
  },
  "13": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "flux2-vae.safetensors"},
    "_meta": {"title": "Load Flux2 VAE"}
  },
  "14": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["12", 0], "vae": ["13", 0]},
    "_meta": {"title": "VAE Decode"}
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": {"images": ["14", 0], "filename_prefix": "ideogram4_smoke"},
    "_meta": {"title": "Save Image"}
  }
}
