# Maya Unified — merged env (copy to maya-unified/.env)
PORT=8090

# --- Voice runtime (packages/voice-runtime/.env) ---
VA_LLM_BASE_URL=http://localhost:1234/v1
VA_LLM_MODEL=local-model
VA_LLM_API_KEY=lm-studio
VA_LLM_TEMPERATURE=0.6
VA_LLM_MAX_TOKENS=220
VA_LLM_ORCHESTRATOR=1
VA_OUTPUT_VOLUME=1.0
VA_WEB_TOOLS_ENABLED=1
VA_OTEL_ENABLED=0
VA_LOG_LEVEL=INFO

# Reasoning provider in dashboard: lm_studio | litellm | webllm (browser only)
# OpenRouter via LiteLLM SDK (recommended hosted path):
# VA_LLM_PROVIDER=litellm
# VA_LLM_LITELLM_MODE=sdk
# VA_LLM_LITELLM_MODEL=openrouter/deepseek/deepseek-v4-flash
# OPENROUTER_API_KEY=sk-or-v1-...
# VA_LLM_API_KEY=sk-or-v1-...
# LM Studio local profile:
# VA_LLM_PROVIDER=lm_studio
# VA_LLM_BASE_URL=http://localhost:1234/v1
# VA_LLM_MODEL=local-model
# VA_LLM_API_KEY=lm-studio

VA_DISCORD_ENABLED=0
VA_DISCORD_TOKEN=
VA_DISCORD_GUILD_ID=
VA_DISCORD_AUTO_REPLY=1
VA_DISCORD_MUSIC_VOLUME=0.85

# --- Platform (optional) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/maya_public

# --- operator auth (dashboard) ---
SESSION_SECRET=change-me-in-production
SESSION_COOKIE_SECURE=0
OPERATOR_DEFAULT_USERNAME=admin
OPERATOR_DEFAULT_PASSWORD=admin

# --- Google OAuth (login + integrations) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MAYA_APP_BASE_URL=http://localhost:8090
MAYA_OAUTH_DYNAMIC_REDIRECT=1
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8090/auth/google/callback
GOOGLE_CONNECT_REDIRECT_URI=http://localhost:8090/api/integrations/google/callback
# Legacy alias (optional): GOOGLE_REDIRECT_URI=http://localhost:8090/auth/google/callback
MAYA_GOOGLE_TOKEN_DIR=.data/google-tokens
# Google Cloud Console → OAuth client → register ALL of these (delete empty URI rows before Save):
# Authorized redirect URIs:
#   http://localhost:8090/auth/google/callback
#   http://localhost:8090/api/platform/auth/callback/google
#   http://localhost:8090/api/integrations/google/callback
#   http://127.0.0.1:8090/auth/google/callback
#   http://127.0.0.1:8090/api/platform/auth/callback/google
#   http://127.0.0.1:8090/api/integrations/google/callback
# Authorized JavaScript origins:
#   http://localhost:8090
#   http://127.0.0.1:8090
# Or run: python scripts/verify_google_oauth.py

COMFYUI_API_URL=http://localhost:3000
MAYA_IMAGE_ROOT=./data/outputs/maya-image
DISCORD_TOKEN=
IMAGINE_SKIP_PORTAL_LINK=1

# WebLLM runs in browser (WebGPU) — no server env required
