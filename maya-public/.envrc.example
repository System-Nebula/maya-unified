# Copy to .envrc (gitignored) and edit. Loaded automatically if you use direnv,
# otherwise `source .envrc` before running gateway/ingest commands.

# Gateway / ingest both read DATABASE_URL via maya_db.connection.get_engine.
export DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5433/maya_public"

# Gateway port — defaults to 8090 because :8080 is commonly taken (AdGuard).
export PORT="8090"

# Optional, needed only for YouTube Data API enrichment + comment fetch.
# Leave unset to use Atom-feed-only path (no comments, no duration enrichment).
# export YOUTUBE_API_KEY=""

# Optional, used by maya-ingest embed_batch flow when EMBED_BACKEND=nomic.
# export NOMIC_API_KEY=""
# export EMBED_BACKEND="local"

# GitHub release diff analysis (raises rate limit when set).
# export GITHUB_TOKEN=""

# LLM analysis for GitHub release diffs (OpenAI-compatible API).
# export LLM_API_KEY=""
# export LLM_MODEL="gpt-4o-mini"
# export LLM_BASE_URL="https://api.openai.com/v1"
# Music ontology graph (read-only for discover ranker; ingest upserts releases).
# export MAYA_ONTOLOGY_DSN="postgresql://postgres:postgres@localhost:5433/maya_public"

# Parent Workspace root for lib/sources (Beatport, Discogs, Bandcamp adapters).
# export MAYA_WORKSPACE_ROOT="$HOME/Workspace"

# Soulseek acquisition (slskd) — used by music_query_cli and ~/Workspace acquisition worker.
# export SLSKD_HOST="http://localhost:5030"
# export SLSKD_API_KEY=""

# Ontology graph DSN for slskd batch ingest + acquisition worker (~/Workspace scripts).
# export MAYA_ONTOLOGY_DSN="postgresql://maya:maya@localhost:5433/maya"

# Discogs API token — required for release tracklist ingest (Dom & Roland fixture).
# export DISCOGS_TOKEN=""

# Optional Genius API token (raises search rate limit; HTML scrape works without).
# export GENIUS_ACCESS_TOKEN=""

# Mailgun webhook signature for POST /api/discover/inbox/webhook (optional in dev).
# export DISCOVER_INBOX_WEBHOOK_SECRET=""
# export ARTIFACT_STORE=local
# export ARTIFACT_STORE_DIR=apps/maya-gateway/src/maya_gateway/static/artifacts

# Research agent — SearXNG, Reddit, LLM synthesis, ontology persistence.
# export RESEARCH_SEARXNG_URL="http://localhost:8080/search"
# export RESEARCH_REDDIT_USER_AGENT="maya-research/0.1 (public research agent)"
# export RESEARCH_OPERATOR_HISTORY_BOOST="0.15"
# export RESEARCH_PRIOR_ART_THRESHOLD="0.3"
# export RESEARCH_MAX_PAGES_PER_RUN="12"
