# Copy to .env and fill in (never commit .env).
VA_DISCORD_ENABLED=1
VA_DISCORD_TOKEN=your_bot_token_here
VA_DISCORD_GUILD_ID=your_server_id_here
VA_DISCORD_MUSIC_VOLUME=0.85
VA_DISCORD_QUEUE_MAX=30
VA_DISCORD_AUTO_REPLY=1

# Agent TTS loudness (0.0–2.0, 1.0 = 100%)
VA_OUTPUT_VOLUME=1.0

# Built-in web search + weather (no API key for weather)
VA_WEB_TOOLS_ENABLED=1

# Logging (always on) — text or json lines to stderr
VA_LOG_LEVEL=INFO
VA_LOG_FORMAT=text

# OpenTelemetry — traces, metrics, and log export to a collector
VA_OTEL_ENABLED=1
VA_OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
VA_OTEL_SERVICE_NAME=qwen3-voice-agent
# VA_LOG_FORMAT=json

# LLM orchestrator — interprets garbled STT + context, routes to tools (default on)
VA_LLM_ORCHESTRATOR=1
# Jaeger UI (after: docker compose -f docker-compose.observability.yml up -d)
# http://localhost:16686
